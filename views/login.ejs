<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Dekrof</title>
     <%- include('./partials/headerlinks')%>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-between">
            <h1 class=" font-bold text-3xl py-5">Dekrof</h1>
            <a href="/helpAndSupport" class="text-blue-500 font-bold">help & support</a>
        </div>
        <h1 class="font-bold text-2xl py-3 text-center">LOGIN</h1>
        <form action="/auth/login" class="w-full flex flex-col items-center gap-2 " method="post">
            <input class=" w-1/2 px-3 py-2 outline-none bg-transparent border -2 border-zinc-800 rounded-lg "  type="email" placeholder="email" name = "email" id="email" required>
            <input class=" w-1/2 px-3 py-2 outline-none bg-transparent border -2 border-zinc-800 rounded-lg "  type="password" placeholder="Password" name = "password" id="password" required>
            <div class="flex justify-start w-1/2 gap-2">
                <input type="checkbox" id="seePassword" class="">
                <label for="seePassword">show password</label>
            </div>
            <input class=" w-96 px-3 py-2 my-3 outline-none  border -2 border-zinc-800 bg-blue-700 rounded-lg font-bold"  type="submit" value="SUBMIT">
        </form>
        <div class="flex justify-center py-3">
            <a href="/auth/register" class="text-center">Don't have an account, Register</a>
        </div>
        <div class="backendMsg">
            <%if(msg){%>
                <p class="text-red-500 text-center"><%=msg%></p>
            <%}%>
        </div>
    </div>
</body>
<script>
        const backendMsg = document.querySelector(".backendMsg");
        const seePassword = document.querySelector("#seePassword");
        const password = document.querySelector("#password");

        setTimeout(()=>{
            backendMsg.innerHTML = "";
        }, 2000 );
        seePassword.addEventListener('change' , (e)=>{
            if (e.target.checked) {
                password.setAttribute("type","text");
            } else {
                password.setAttribute("type","password");
            }
        });
    </script>
</html>