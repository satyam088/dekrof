<div class="max-w-2xl mx-auto mt-8 bg-zinc-900 rounded-2xl p-6">

    <h1 class="text-2xl font-bold text-white mb-6">
        Create Post
    </h1>

    <form
        action="/post/create"
        method="POST"
        enctype="multipart/form-data"
        class="space-y-6">

        <div>

            <label
                class="block text-zinc-300 mb-2 font-medium">

                Upload Images
            </label>

            <input
                type="file"
                name="images"
                multiple
                accept="image/*"
                id="images"
                class="block w-full text-zinc-300
                file:mr-4
                file:py-2
                file:px-4
                file:rounded-lg
                file:border-0
                file:bg-blue-600
                file:text-white
                hover:file:bg-blue-700">

        </div>

        <div
            id="previewContainer"
            class="grid grid-cols-2 md:grid-cols-3 gap-4">
        </div>

        <div>

            <label
                class="block text-zinc-300 mb-2 font-medium">

                Content
            </label>

            <textarea
                name="content"
                rows="6"
                placeholder="What's happening?"
                class="w-full bg-zinc-800
                text-white
                rounded-xl
                p-4
                resize-none
                outline-none
                border border-zinc-700
                focus:border-blue-500"></textarea>

        </div>


        <button
            type="submit"
            class="w-full bg-blue-600
            hover:bg-blue-700
            text-white
            font-semibold
            py-3
            rounded-xl">

            Create Post

        </button>

    </form>

</div>