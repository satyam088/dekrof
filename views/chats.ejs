<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <%- include('./partials/headerlinks')%>
</head>
<body>
    <div class="root  w-full h-screen flex flex-col bg-zinc-900 pt-10 text-white" data-curruser-name = "<%=currUser.username%>">

        <div class="return px-10 h-15">
            <a href="/home" class="text-blue-400">return to home page</a>
        </div>

        <div class="main flex flex-1 gap-2 mt-5 overflow-hidden mb-5">
            <div class="ChatContainer w-80 flex flex-col overflow-y-auto gap-1 text-xl font-bold">

                <%if(conversations && conversations.length !=0){%>
                    <%conversations.forEach(conversation =>{%>
                        <div class="user bg-zinc-700 h-16 w-full flex items-center gap-2 pl-4 py-2 cursor-pointer"
                            data-conversation-id ="<%=conversation._id%>"
                            data-username = "<%=conversation.otherUserInfo.username%> ">

                            <img src="<%=conversation.otherUserInfo.profilepic.url%>" alt="" class="w-10 rounded-full">
                            <div class=" flex flex-col gap-1  justify-center">
                                <h1><%=conversation.otherUserInfo.name%> </h1>
                                <p class="text-xs text-zinc-500"><%=conversation.lastMessage%></p>
                            </div>
                        </div>
                    <%});%>
                <%}%>

            </div>
            <div class="chatbox w-full flex-1 bg-zinc-800/30 backdrop-blur-md shadow-lg border-2 border-zinc-700 h-full mx-3 flex flex-col rounded-lg overflow-hidden"
                    data-conversation-id="<%=userToChatWith.conversationId%>"
                    data-in-chat-user="<%=userToChatWith.username%>"
                    data-last-message-id="abc">

                    <div class="userinfo bg-zinc-700 h-16 flex gap-2 items-center pl-4" id="userinfodiv">
                        <div class="image w-14 rounded-full overflow-hidden">
                            <a href="/user/view/<%=userToChatWith.username%>">
                                <img src="<%=userToChatWith.profilepic.url%>" alt="" class="overflow-hidden rounded-full w-14 h-14 currUserProfilepic" >
                             </a>
                        </div>
                        <div class="username text-2xl font-bold">
                            <a href="/user/view/<%=userToChatWith.username%>" class="CurrUsername" ><%=userToChatWith.username%></a>
                        </div>
                    </div>

                <div class="chat_messages flex-1 flex flex-col overflow-y-auto pt-2">
                    <div class="loadChats"></div>
                </div>

                <form action="" class="ipform">
                <div class="chat-input h-16 bg-zinc-700  flex ">
                        <input type="text" class=" ipmsg h-16 bg-transparent outline-none   flex-1 text-2xl px-2" placeholder="message...">
                    <button class="send w-16 bg-blue-700">
                        <i class="fa-regular fa-paper-plane text-3xl"></i>
                    </button>
                </div>
                </form>
            </div>
        </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/javascripts/chats.js"></script>
</body>
</html>