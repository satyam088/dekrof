<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <%- include('./partials/headerlinks')%>
</head>
<body>
    <div class="root  w-full h-screen flex flex-col bg-zinc-900 pt-10 text-white">

        <div class="return px-10 h-15">
            <a href="/home" class="text-blue-400">return to home page</a>
        </div>

        <div class="main flex flex-1 gap-2 mt-5 overflow-hidden mb-5">
            <div class="ChatContainer w-80 flex flex-col overflow-y-auto gap-1 text-xl font-bold">
                <div class="user bg-zinc-700 h-16 w-full flex items-center">
                    <img src="" alt="" class="w-16 rounded-full">
                    <h1>user1</h1>
                </div>
                <div class="user bg-zinc-700 h-16 w-full flex items-center">
                    <img src="" alt="" class="w-16 rounded-full">
                    <h1>user2</h1>
                </div>
                <div class="user bg-zinc-700 h-16 w-full flex items-center">
                    <img src="" alt="" class="w-16 rounded-full">
                    <h1>user3</h1>
                </div>
            </div>
            <div class="chatbox w-full flex-1 bg-zinc-800/30 backdrop-blur-md shadow-lg border-2 border-zinc-700 h-full mx-3 flex flex-col rounded-lg overflow-hidden">

                <div class="userinfo bg-zinc-700 h-16 flex gap-2 items-center">
                    <div class="image w-16 rounded-full overflow-hidden">
                        <img src="" alt="" class="overflow-hidden rounded-full">
                    </div>
                    <div class="username text-2xl font-bold">
                        Satyam Chauhan
                    </div>

                </div>

                <div class="chat_messages flex-1 flex-col">

                </div>

                <form action="" class="ipform">
                <div class="chat-input h-16 bg-zinc-700  flex ">
                        <input type="text" class=" ipmsg h-16 bg-transparent outline-none   flex-1 text-2xl px-2" placeholder="message...">
                    <button class="send w-16 bg-blue-700">
                        <i class="fa-regular fa-paper-plane text-3xl"></i>
                    </button>
                </div>
            </form>
            </div>
        </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/javascripts/chats.js"></script>
</body>
</html>