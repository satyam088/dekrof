<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <%- include('./partials/headerlinks')%>
</head>
<body>
    <div class="main px-10 w-full min-h-screen bg-zinc-900 pt-10">
        <div class="return">
            <a href="/user/view/<%=user.username%>" class="text-blue-400">return to previous page</a>
        </div>
        <div class="heading flex items-center text-2xl font-bold mt-5 justify-center ">
            <h1 class="text-white mr-5">Followers of </h1>
            <a href="/user/view/<%=user.username%>" class="text-blue-400">@<%=user.username%></a>
        </div>
        <div class="allUsers flex flex-col gap-5 items-center mt-10">
            <%if(user.followers.length !=0 ){%>
                <%user.followers.forEach(follower =>{%>
                    <div class=" flex bg-zinc-700 px-4 py-4 rounded-3xl  min-w-64">
                    <div class="profilepic h-12 w-12 rounded-full mr-2">
                        <img src="<%=follower.profilepic.url%>" alt="profilepis" class="w-full h-full object-cover rounded-full">
                    </div>
                    <div>
                        <a href="/user/view/<%=follower.username%>" class="text-blue-400">@<%=follower.username%></a>
                        <p class="font-bold"><%=follower.name%></p>
                    </div>
                </div>
                <%})%>
            <%}%>
        </div>
    </div>
</body>
</html>