<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <%- include('./partials/headerlinks')%>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900  text-white">

    <%- include('./partials/navbar') %>

    <main class="max-w-2xl mx-auto py-8 px-4">

        <% if(posts.length === 0){ %>

            <div class="text-center mt-20">
                <h2 class="text-2xl font-semibold">
                    No posts yet
                </h2>

                <p class="text-zinc-400 mt-2">
                    Follow users or create your first post.
                </p>
            </div>

        <% }else{ %>

        <% posts.forEach(post => { %>

            <article
                class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden mb-6">

                <div class="flex items-center gap-3 p-4">

                    <a href="/user/view/<%= post.user.username %>">

                        <img
                            src="/images/uploads/<%=post.user.profilepic || 'https://via.placeholder.com/100' %>"
                            class="w-12 h-12 rounded-full object-cover"
                            alt="profile">

                    </a>

                    <div>
                        <a
                            href="/user/view/<%= post.user %>"
                            class="font-semibold hover:text-blue-400">

                            @<%= post.user.username %>

                        </a>

                        <p class="text-xs text-zinc-400">
                            <%= new Date(post.createdAt).toLocaleDateString() %>
                        </p>
                    </div>

                </div>

                <% if(post.image){ %>

                    <img
                        src="<%= post.image %>"
                        alt="post image"
                        class="w-full max-h-[600px] object-cover">

                <% } %>

                <% if(post.content){ %>

                    <div class="px-4 py-3">
                        <p class="whitespace-pre-line">
                            <%= post.content %>
                        </p>
                    </div>

                <% } %>

                <div
                    class="flex items-center justify-between px-4 py-3 border-t border-zinc-800">

                    <div class="flex items-center gap-6">

                        <a
                            href="/post/like/<%= post._id %>"
                            class="flex items-center gap-2 hover:text-red-400">

                            <i class="fa-regular fa-heart text-xl"></i>

                            <span>
                                <%= post.likes.length %>
                            </span>

                        </a>

                        <a
                            href="/post/<%= post._id %>"
                            class="flex items-center gap-2 hover:text-blue-400">

                            <i class="fa-regular fa-comment text-xl"></i>

                            <span>
                                <%= post.comments.length %>
                            </span>

                        </a>

                    </div>

                </div>

            </article>

        <% }) %>
        <%}%>

    </main>

</body>
</html>

    </div>
</body>
</html>